apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: nodered
  namespace: apps
  labels:
    app.kubernetes.io/name: nodered
    app.kubernetes.io/part-of: minidev-platform
    app.kubernetes.io/component: routing
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ nodered_hostname }}`)
      kind: Rule
      middlewares:
        - name: default-security-headers
          namespace: traefik
      services:
        - name: nodered
          port: 1880
  tls:
    certResolver: {{ traefik_acme_resolver_name }}
