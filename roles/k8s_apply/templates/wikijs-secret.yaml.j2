apiVersion: v1
kind: Secret
metadata:
  name: wikijs-secret
  namespace: apps
  labels:
    app.kubernetes.io/name: wikijs
    app.kubernetes.io/part-of: minidev-platform
    app.kubernetes.io/component: secret
type: Opaque
stringData:
  DB_TYPE: postgres
  DB_HOST: wikijs-postgres
  DB_PORT: "5432"
  DB_NAME: wikijs
  DB_USER: wikijs
  DB_PASS: "{{ wikijs_db_password }}"