apiVersion: v1
kind: Secret
metadata:
  name: gitea-secret
  namespace: apps
  labels:
    app.kubernetes.io/name: gitea
    app.kubernetes.io/part-of: minidev-platform
    app.kubernetes.io/component: secret
type: Opaque
stringData:
  GITEA__database__DB_TYPE: postgres
  GITEA__database__HOST: apps-postgres:5432
  GITEA__database__NAME: gitea
  GITEA__database__USER: gitea
  GITEA__database__PASSWD: "{{ gitea_db_password }}"

  GITEA__server__DOMAIN: "{{ gitea_hostname }}"
  GITEA__server__ROOT_URL: "https://{{ gitea_hostname }}/"
  GITEA__server__HTTP_ADDR: "0.0.0.0"
  GITEA__server__HTTP_PORT: "3000"

  GITEA__server__START_SSH_SERVER: "false"
  GITEA__server__SSH_DOMAIN: "{{ gitea_hostname }}"
  GITEA__server__SSH_PORT: "22"
  GITEA__server__SSH_LISTEN_HOST: "0.0.0.0"
  GITEA__server__SSH_LISTEN_PORT: "22"

  GITEA__service__DISABLE_REGISTRATION: "true"