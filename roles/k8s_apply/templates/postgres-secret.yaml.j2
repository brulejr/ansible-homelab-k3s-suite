apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: apps
  labels:
    app.kubernetes.io/name: wikijs-postgres
    app.kubernetes.io/part-of: minidev-platform
    app.kubernetes.io/component: secret
type: Opaque
stringData:
  POSTGRES_DB: wikijs
  POSTGRES_USER: wikijs
  POSTGRES_PASSWORD: "{{ wikijs_db_password }}"