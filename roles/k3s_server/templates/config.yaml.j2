write-kubeconfig-mode: "{{ k3s_write_kubeconfig_mode }}"
token: "{{ k3s_server_token }}"
cluster-cidr: "{{ k3s_cluster_cidr }}"
service-cidr: "{{ k3s_service_cidr }}"
cluster-domain: "{{ k3s_cluster_domain }}"
default-local-storage-path: "{{ k3s_default_local_storage_path }}"

{% if k3s_cluster_dns | length > 0 %}
cluster-dns: "{{ k3s_cluster_dns }}"
{% endif %}

{% if k3s_disable | length > 0 %}
disable:
{% for item in k3s_disable %}
  - "{{ item }}"
{% endfor %}
{% endif %}

{% if k3s_tls_sans | length > 0 %}
tls-san:
{% for san in k3s_tls_sans %}
  - "{{ san }}"
{% endfor %}
{% endif %}

{% if k3s_kube_apiserver_args | length > 0 %}
kube-apiserver-arg:
{% for arg in k3s_kube_apiserver_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

{% if k3s_kube_controller_manager_args | length > 0 %}
kube-controller-manager-arg:
{% for arg in k3s_kube_controller_manager_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

{% if k3s_kube_scheduler_args | length > 0 %}
kube-scheduler-arg:
{% for arg in k3s_kube_scheduler_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}

{% if k3s_kubelet_args | length > 0 %}
kubelet-arg:
{% for arg in k3s_kubelet_args %}
  - "{{ arg }}"
{% endfor %}
{% endif %}